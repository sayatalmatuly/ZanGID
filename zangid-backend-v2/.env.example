# ────────────────────────────────────────────────────────────────
#  ZanGID Backend — пример переменных окружения
#  Скопируй файл в .env и заполни значения:
#    cp .env.example .env
# ────────────────────────────────────────────────────────────────

# ── OpenAI (ОБЯЗАТЕЛЬНО) ─────────────────────────────────────────
# Получить на: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Модель. Рекомендуем gpt-4.1 или gpt-4o
OPENAI_MODEL=gpt-4.1

# ── Supabase (ОПЦИОНАЛЬНО) ───────────────────────────────────────
# Без Supabase история чатов не загружается, остальное работает.
# Найти в: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Сервер ───────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0

# CORS: укажи точный домен фронтенда на проде, например:
#   CORS_ORIGIN=https://zangid.kz
# На локалке можно оставить *
CORS_ORIGIN=*

# STATIC_DIR: папка с собранным фронтендом.
# Если фронт лежит рядом с бекендом, укажи путь к папке ZanGid1:
#   STATIC_DIR=../ZanGid1
# По умолчанию — текущая директория (рядом с app.py)
STATIC_DIR=.

# ── Режим отладки ────────────────────────────────────────────────
# true — подробные ошибки в браузере (только для разработки!)
FLASK_DEBUG=false
